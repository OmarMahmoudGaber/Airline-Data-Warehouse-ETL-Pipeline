      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0021\\Skipped run of job '%1' on restart", jb$V0S40), "@Marketing_Mart")
      job$V0S40$status = Raise(cp$value<1>)
      job$V0S40$userstatus = Raise(cp$value<2>)
      IdV0S40%%Result2%%30 = job$V0S40$userstatus
      IdV0S40%%Result1%%31 = job$V0S40$status
      IdV0S40%%Name%%32 = jb$V0S40
      summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0060\\%1 (JOB %2) skipped", "Marketing_Mart":@FM:jb$V0S40))
      b$V0S40skipping = @True
      Goto L$V0S40$SKIPPED
   End
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0057\\%1 (JOB %2) started", "Marketing_Mart":@FM:jb$V0S40))
   h$V0S40 = DSAttachJob(jb$V0S40, DSJ.ERRNONE)
   If (Not(h$V0S40)) Then
      err$source = "Marketing_Mart"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0001\\Error calling DSAttachJob(%1)<L>%2", jb$V0S40:@FM:DSGetLastErrorMsg())
      msg$id = "@Marketing_Mart"; GoTo L$ERROR
   End
   If Not(b$CPRestarted) Then GoTo L$V0S40$PREPARED
   h$V0S40 = DSPrepareJob(h$V0S40)
   If (Not(h$V0S40)) Then
      err$source = "Marketing_Mart"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0012\\Error calling DSPrepareJob(%1)<L>%2", jb$V0S40:@FM:DSGetLastErrorMsg())
      msg$id = "@Marketing_Mart"; GoTo L$ERROR
   End
L$V0S40$PREPARED:
   err$code = DSRunJob(h$V0S40, DSJ.RUNNORMAL)
   If (err$code <> DSJE.NOERROR) Then
      err$source = "Marketing_Mart"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0003\\Error calling DSRunJob(%1), code=%2[E]", jb$V0S40:@FM:err$code)
      msg$id = "@Marketing_Mart"; GoTo L$ERROR
   End
   handle$list<-1> = h$V0S40
   id$list<-1> = "V0S40"
   GoTo L$V0S42$RETURN$2
**************************************************
L$V0S40$FINISHED:
   job$V0S40$status = DSGetJobInfo(h$V0S40, DSJ.JOBSTATUS)
   job$V0S40$userstatus = DSGetJobInfo(h$V0S40, DSJ.USERSTATUS)
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0063\\%1 (JOB %2) finished, status=%3[E]", "Marketing_Mart":@FM:jb$V0S40:@FM:job$V0S40$status))
   IdV0S40%%Result2%%30 = job$V0S40$userstatus
   IdV0S40%%Result1%%31 = job$V0S40$status
   IdV0S40%%Name%%32 = jb$V0S40
   If (job$V0S40$status <> DSJS.RUNOK) Then
      Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0030\\Job %1 did not finish OK, status = '%2'", jb$V0S40:@FM:DSTranslateCode(job$V0S40$status)), "@Marketing_Mart")
   End
   dummy$ = DSDetachJob(h$V0S40)
   If b$InErrorRef$V0S40 Or (job$V0S40$status <> DSJS.RUNOK And job$V0S40$status <> DSJS.RUNWARN) Then Goto L$V0S40$SKIPPED
   cp$value = Lower(job$V0S40$status)
   cp$value<2> = Lower(job$V0S40$userstatus)
   dummy$ = DSCheckPointSetValue(DSJ.ME, h$V0S40$cp, cp$value)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0025\\Checkpointed run of job '%1'", jb$V0S40), "@Marketing_Mart")
**************************************************
L$V0S40$SKIPPED:
   If b$V0S40skipping Then GoTo L$V0S42$RETURN$2
   GoTo L$WAITFORJOB
**************************************************
L$V0S41$START:
*** Activity "Finances_Mart": Initialize job
   b$InErrorRef$V0S41 = b$InErrorRef
   jb$V0S41 = "Load_Mart_Finance"
   b$V0S41skipping = @False
   h$V0S41$cp = "h$V0S41"
   If DSCheckPointGetValue(DSJ.ME, h$V0S41$cp, cp$value) = DSJE.NOERROR Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0021\\Skipped run of job '%1' on restart", jb$V0S41), "@Finances_Mart")
      job$V0S41$status = Raise(cp$value<1>)
      job$V0S41$userstatus = Raise(cp$value<2>)
      IdV0S41%%Result2%%33 = job$V0S41$userstatus
      IdV0S41%%Result1%%34 = job$V0S41$status
      IdV0S41%%Name%%35 = jb$V0S41
      summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0060\\%1 (JOB %2) skipped", "Finances_Mart":@FM:jb$V0S41))
      b$V0S41skipping = @True
      Goto L$V0S41$SKIPPED
   End
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0057\\%1 (JOB %2) started", "Finances_Mart":@FM:jb$V0S41))
   h$V0S41 = DSAttachJob(jb$V0S41, DSJ.ERRNONE)
   If (Not(h$V0S41)) Then
      err$source = "Finances_Mart"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0001\\Error calling DSAttachJob(%1)<L>%2", jb$V0S41:@FM:DSGetLastErrorMsg())
      msg$id = "@Finances_Mart"; GoTo L$ERROR
   End
   If Not(b$CPRestarted) Then GoTo L$V0S41$PREPARED
   h$V0S41 = DSPrepareJob(h$V0S41)
   If (Not(h$V0S41)) Then
      err$source = "Finances_Mart"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0012\\Error calling DSPrepareJob(%1)<L>%2", jb$V0S41:@FM:DSGetLastErrorMsg())
      msg$id = "@Finances_Mart"; GoTo L$ERROR
   End
L$V0S41$PREPARED:
   err$code = DSRunJob(h$V0S41, DSJ.RUNNORMAL)
   If (err$code <> DSJE.NOERROR) Then
      err$source = "Finances_Mart"; err$number = -1
      msg$ = DSMakeMsg("DSTAGE_JSG_M_0003\\Error calling DSRunJob(%1), code=%2[E]", jb$V0S41:@FM:err$code)
      msg$id = "@Finances_Mart"; GoTo L$ERROR
   End
   handle$list<-1> = h$V0S41
   id$list<-1> = "V0S41"
   GoTo L$V0S42$RETURN$1
**************************************************
L$V0S41$FINISHED:
   job$V0S41$status = DSGetJobInfo(h$V0S41, DSJ.JOBSTATUS)
   job$V0S41$userstatus = DSGetJobInfo(h$V0S41, DSJ.USERSTATUS)
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0063\\%1 (JOB %2) finished, status=%3[E]", "Finances_Mart":@FM:jb$V0S41:@FM:job$V0S41$status))
   IdV0S41%%Result2%%33 = job$V0S41$userstatus
   IdV0S41%%Result1%%34 = job$V0S41$status
   IdV0S41%%Name%%35 = jb$V0S41
   If (job$V0S41$status <> DSJS.RUNOK) Then
      Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0030\\Job %1 did not finish OK, status = '%2'", jb$V0S41:@FM:DSTranslateCode(job$V0S41$status)), "@Finances_Mart")
   End
   dummy$ = DSDetachJob(h$V0S41)
   If b$InErrorRef$V0S41 Or (job$V0S41$status <> DSJS.RUNOK And job$V0S41$status <> DSJS.RUNWARN) Then Goto L$V0S41$SKIPPED
   cp$value = Lower(job$V0S41$status)
   cp$value<2> = Lower(job$V0S41$userstatus)
   dummy$ = DSCheckPointSetValue(DSJ.ME, h$V0S41$cp, cp$value)
   Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0025\\Checkpointed run of job '%1'", jb$V0S41), "@Finances_Mart")
**************************************************
L$V0S41$SKIPPED:
   If b$V0S41skipping Then GoTo L$V0S42$RETURN$1
   GoTo L$WAITFORJOB
**************************************************
L$V0S42$START:
*** Sequencer "Marts_sequencer": wait until inputs ready
   seq$V0S42$status = 1
   seq$V0S42$count += 1
   If seq$V0S42$count < 2 Then Return
   seq$V0S42$status = 2
   GoTo L$V0S41$START
L$V0S42$RETURN$1:
   GoTo L$V0S40$START
L$V0S42$RETURN$2:
   Return
**************************************************
L$WAITFORJOB:
   If handle$list = "" Then GoTo L$FINISH
   handle$ = DSWaitForJob(handle$list)
   If handle$ = 0 Then handle$ = handle$list<1>
   Locate handle$ In handle$list Setting index$ Then
      id$ = id$list<index$>
      Del id$list<index$>; Del handle$list<index$>
      b$Abandoning = abort$list<index$>; Del abort$list<index$>
      Begin Case
      Case id$ = "V0S0"
         GoTo L$V0S0$FINISHED
      Case id$ = "V0S1"
         GoTo L$V0S1$FINISHED
      Case id$ = "V0S2"
         GoTo L$V0S2$FINISHED
      Case id$ = "V0S3"
         GoTo L$V0S3$FINISHED
      Case id$ = "V0S9"
         GoTo L$V0S9$FINISHED
      Case id$ = "V0S10"
         GoTo L$V0S10$FINISHED
      Case id$ = "V0S13"
         GoTo L$V0S13$FINISHED
      Case id$ = "V0S14"
         GoTo L$V0S14$FINISHED
      Case id$ = "V0S17"
         GoTo L$V0S17$FINISHED
      Case id$ = "V0S20"
         GoTo L$V0S20$FINISHED
      Case id$ = "V0S40"
         GoTo L$V0S40$FINISHED
      Case id$ = "V0S41"
         GoTo L$V0S41$FINISHED
      End Case
   End
* Error if fall though
   handle$list = ""
   err$source = "@Coordinator"; err$number = -1
   msg$ = DSMakeMsg("DSTAGE_JSG_M_0008\\Error calling DSWaitForJob(), code=%1[E]", handle$)
   msg$id = "@Coordinator"; GoTo L$ERROR
**************************************************
L$ERROR:
   Call DSLogWarn(DSMakeMsg("DSTAGE_JSG_M_0009\\Controller problem: %1", msg$), msg$id)
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0052\\Exception raised: %1", msg$id:", ":msg$))
   If Not(b$InErrorRef) Then
      dummy$ = DSCheckPointSetValue(DSJ.ME, "!", DSMakeMsg("DSTAGE_JSG_M_0031\\Failed at: %1, Reason=%2", err$source:@FM:msg$))
   End
   abort$list = Ifs(handle$list, Str(1:@FM, DCount(handle$list, @FM)), "")
   b$Abandoning = @True
   GoTo L$WAITFORJOB
L$ABORT:
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0055\\Sequence failed (restartable)", ""))
   Call DSLogInfo(summary$, "@Coordinator")
   Call DSLogFatal(DSMakeMsg("DSTAGE_JSG_M_0014\\Sequence job (restartable) will abort due to previous unrecoverable errors", ""), "@Coordinator")
**************************************************
L$FINISH:
   If b$Abandoning Then GoTo L$ABORT
   If b$NumStarted < 6 Then GoTo L$INITIAL
*** At successful exit remove checkpoint record
   If Not(b$InErrorRef) And DSCheckPointExists(DSJ.ME, cp$dtm) Then
      dummy$ = DSCheckPointDelete(DSJ.ME)
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0018\\Removed checkpoint record at successful completion of sequence", ""), "@Coordinator")
   End
   If (seq$V0S25$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Dimensions_Sequencer"), "@Coordinator")
   End
   If (seq$V0S29$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Facts_Sequencer"), "@Coordinator")
   End
   If (seq$V0S42$status = 1) Then
      Call DSLogInfo(DSMakeMsg("DSTAGE_JSG_M_0072\\Note: Sequencer '%1' was entered, but never exited", "Marts_sequencer"), "@Coordinator")
   End
   summary$<1,-1> = Time$$:Convert(@VM, " ", DSMakeMsg("DSTAGE_JSG_M_0054\\Sequence finished OK", ""))
   Call DSLogInfo(summary$, "@Coordinator")
   L$EXIT: Return To L$EXIT
 

