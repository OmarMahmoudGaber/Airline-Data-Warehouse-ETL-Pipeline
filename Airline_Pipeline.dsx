#################################################################
#### STAGE: RESERVATION_TICKET_AIRCRAFT
## Operator
pxbridge
## Operator options
-Orientation link
-XMLProperties '<?xml version=\\'1.0\\' encoding=\\'UTF-16\\'?><Properties version=\\'1.1\\'><Common><Context type=\\'int\\'>1</Context><Variant type=\\'string\\'>10g</Variant><DescriptorVersion type=\\'string\\'>1.0</DescriptorVersion><PartitionType type=\\'int\\'>-1</PartitionType><RCP type=\\'int\\'>0</RCP></Common><Connection><Server modified=\\'1\\' type=\\'string\\'><![CDATA[XE]]></Server><Username modified=\\'1\\' type=\\'string\\'><![CDATA[HR]]></Username><Password modified=\\'1\\' type=\\'protectedstring\\'><![CDATA[{iisenc}k5odSEVP9wf4hGL0TXie1w==]]></Password><OSLevelAuthentication type=\\'bool\\'><![CDATA[0]]></OSLevelAuthentication><Version type=\\'string\\'><![CDATA[10g]]></Version></Connection><Usage><ReadMode modified=\\'1\\' type=\\'int\\'><![CDATA[0]]></ReadMode><GenerateSQL modified=\\'1\\' type=\\'bool\\'><![CDATA[0]]></GenerateSQL><EnableQuotedIDs type=\\'bool\\'><![CDATA[0]]></EnableQuotedIDs><SQL><SelectStatement modified=\\'1\\' type=\\'string\\'><![CDATA[ SELECT 
    t.TICKET_ID, 
    r.BOOKING_DATE, 
    r.PASSENGER_ID, 
    r.FLIGHT_ID, 
    r.CHANNEL_ID, 
    t.FARE_CLASS_ID, 
    t.BASE_FARE_USD, 
    t.TAX_AMOUNT_USD, 
    t.FEE_AMOUNT_USD, 
    t.DISCOUNT_AMOUNT_USD, 
    t.FINAL_TICKET_AMOUNT_USD, 
    NVL(c.TOTAL_COST_USD, 0) AS TOTAL_FLIGHT_COST,
    -- Add all seat capacities together to get total plane capacity
    (NVL(a.CAPACITY_ECONOMY, 0) + NVL(a.CAPACITY_BUSINESS, 0) + NVL(a.CAPACITY_FIRST, 0)) AS TOTAL_PASSENGER_CAPACITY
FROM TICKETS t
INNER JOIN RESERVATIONS r ON t.RESERVATION_ID = r.RESERVATION_ID
LEFT JOIN FLIGHTS f ON r.FLIGHT_ID = f.FLIGHT_ID
LEFT JOIN AIRCRAFT a ON f.AIRCRAFT_ID = a.AIRCRAFT_ID
